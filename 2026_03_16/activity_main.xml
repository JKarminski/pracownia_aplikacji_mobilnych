<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#90EE90"
    android:padding="16dp">

    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wizyta u weterynarza"
        android:textSize="22sp"
        android:textStyle="bold"
        android:background="#2E8B57"
        android:textColor="#FFFFFF"
        android:padding="10dp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/ownerNameEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Imie i nazwisko wlasciciela..."
        android:inputType="textPersonName"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/speciesLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gatunek"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <RadioGroup
        android:id="@+id/speciesRadioGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">

        <RadioButton
            android:id="@+id/dogRadioButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pies" />

        <RadioButton
            android:id="@+id/catRadioButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kot" />

        <RadioButton
            android:id="@+id/guineaPigRadioButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Swinka morska" />
    </RadioGroup>

    <LinearLayout
        android:id="@+id/ageRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/ageLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ile ma lat?"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/ageValueTextView"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:gravity="center"
            android:layout_marginEnd="8dp" />

        <SeekBar
            android:id="@+id/ageSeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="20"
            android:progress="0" />
    </LinearLayout>

    <EditText
        android:id="@+id/purposeEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Cel wizyty"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/timeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Godzina"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/timeEditText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:focusable="false"
        android:clickable="true"
        android:inputType="none"
        android:text="16:00"
        android:padding="8dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/okButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="OK" />

    <TextView
        android:id="@+id/resultTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:layout_marginTop="12dp"
        android:textColor="#000000" />

</LinearLayout>
