<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">


    <ImageView
        android:id="@+id/logo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/logo"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="30dp"
        android:contentDescription="@string/logo"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        >


        <TextView
            android:id="@+id/no_uniform"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_uniform"
            style="@style/header"
            />

        <TextView
            android:id="@+id/name_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/Imie"
            style="@style/label"
            />


        <TextView
            android:id="@+id/reported_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            style="@style/reported"
            />

        <TextView
            android:id="@+id/surname_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/Nazwisko"
            style="@style/label"
            />

        <TextView
            android:id="@+id/reported_surname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:text=""
            style="@style/reported"
            />

        <TextView
            android:id="@+id/class_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/Klasa"
            style="@style/label"
            />

        <TextView
            android:id="@+id/reported_class"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:text=""
            style="@style/reported"/>

        <Button
            android:id="@+id/save_note_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ZAPISZ UWAGĘ"
            style="@style/button"
            />
    </LinearLayout>

</LinearLayout>